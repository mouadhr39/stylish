<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:jcr="http://www.jcp.org/jcr/1.0" xmlns:nt="http://www.jcp.org/jcr/nt/1.0" xmlns:mix="http://www.jcp.org/jcr/mix/1.0" xmlns:cq="http://www.day.com/jcr/cq/1.0" xmlns:sling="http://sling.apache.org/jcr/sling/1.0"
    jcr:primaryType="cq:Page">
    <jcr:content
        cq:tags="[experience-fragments:variation/web]"
        cq:template="/conf/stylish/settings/wcm/templates/xf-header-footer-container"
        cq:xfMasterVariation="{Boolean}true"
        cq:xfVariantType="web"
        jcr:isCheckedOut="{Boolean}true"
        jcr:mixinTypes="[mix:versionable]"
        jcr:primaryType="cq:PageContent"
        jcr:title="Header"
        jcr:uuid="22428fc1-af25-410d-b3d8-c34b97873a0b"
        sling:resourceType="stylish/components/xfpage">
        <root
            jcr:primaryType="nt:unstructured"
            sling:resourceType="stylish/components/container"
            layout="responsiveGrid">
            <hfcontainer
                jcr:primaryType="nt:unstructured"
                sling:resourceType="stylish/components/hfcontainer"
                layout="responsiveGrid"
                type="header">
                <topheader
                    jcr:primaryType="nt:unstructured"
                    sling:resourceType="stylish/components/topheader"
                    offerText="&lt;p>&lt;b>Special Offer:&lt;/b> &lt;u>Free Shipping&lt;/u> on all the orders above $100&amp;nbsp;&lt;/p>&#xd;&#xa;"
                    textIsRich="true">
                    <socialMediaLinks jcr:primaryType="nt:unstructured">
                        <item0
                            jcr:primaryType="nt:unstructured"
                            icon="facebook"
                            link="https://www.facebook.com"/>
                        <item1
                            jcr:primaryType="nt:unstructured"
                            icon="instagram"
                            link="https://www.instagram.com"/>
                        <item2
                            jcr:primaryType="nt:unstructured"
                            icon="youtube"
                            link="https://www.youtube.com"/>
                        <item3
                            jcr:primaryType="nt:unstructured"
                            icon="pinterest"
                            link="https://www.pinterest.com"/>
                    </socialMediaLinks>
                    <pageLinks jcr:primaryType="nt:unstructured">
                        <item0
                            jcr:primaryType="nt:unstructured"
                            pageLink="/content/stylish/en/en"
                            pageTitle="Contact"/>
                        <item1
                            jcr:primaryType="nt:unstructured"
                            pageLink="/content/stylish/en/en"
                            pageTitle="Cart"/>
                        <item2
                            jcr:primaryType="nt:unstructured"
                            pageLink="/content/stylish/en/en"
                            pageTitle="Login"/>
                    </pageLinks>
                </topheader>
                <navigation
                    jcr:primaryType="nt:unstructured"
                    sling:resourceType="stylish/components/navigation"
                    brandLogoAltText="home"
                    brandLogoFileReference="/content/dam/stylish/main-logo.png"
                    brandLogoLink="/content/stylish/en/en"
                    collectAllPages="true"
                    disableShadowing="false"
                    navigationRoot="/content/stylish/it/en"
                    structureDepth="2"
                    structureStart="1">
                    <iconsMenu jcr:primaryType="nt:unstructured">
                        <item0
                            jcr:primaryType="nt:unstructured"
                            icon="user"
                            modalTarget="modallogin"/>
                        <item1
                            jcr:primaryType="nt:unstructured"
                            icon="shopping-cart"
                            modalTarget="modallong"/>
                        <item2
                            jcr:primaryType="nt:unstructured"
                            icon="search"
                            modalTarget="search-box"/>
                    </iconsMenu>
                </navigation>
            </hfcontainer>
        </root>
    </jcr:content>
</jcr:root>
