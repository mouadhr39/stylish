<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:jcr="http://www.jcp.org/jcr/1.0" xmlns:nt="http://www.jcp.org/jcr/nt/1.0" xmlns:mix="http://www.jcp.org/jcr/mix/1.0" xmlns:cq="http://www.day.com/jcr/cq/1.0" xmlns:sling="http://sling.apache.org/jcr/sling/1.0"
    jcr:primaryType="cq:Page">
    <jcr:content
        cq:tags="[experience-fragments:variation/web]"
        cq:template="/conf/stylish/settings/wcm/templates/xf-header-footer-container"
        cq:xfVariantType="web"
        jcr:isCheckedOut="{Boolean}true"
        jcr:mixinTypes="[cq:LiveRelationship,cq:LiveSync,mix:versionable]"
        jcr:primaryType="cq:PageContent"
        jcr:title="Header Only Nav"
        jcr:uuid="eed2e9e5-2ff5-4e4a-a775-3e073a1e9bc9"
        sling:resourceType="stylish/components/xfpage">
        <root
            jcr:mixinTypes="[cq:LiveRelationship]"
            jcr:primaryType="nt:unstructured"
            sling:resourceType="stylish/components/container"
            layout="responsiveGrid">
            <hfcontainer
                cq:lastRolledout="{Date}2026-05-12T16:29:07.665+02:00"
                cq:lastRolledoutBy="admin"
                jcr:mixinTypes="[cq:LiveRelationship]"
                jcr:primaryType="nt:unstructured"
                sling:resourceType="stylish/components/hfcontainer"
                layout="responsiveGrid"
                type="header">
                <navigation
                    jcr:mixinTypes="[cq:LiveRelationship]"
                    jcr:primaryType="nt:unstructured"
                    sling:resourceType="stylish/components/navigation"
                    brandLogoAltText="home"
                    brandLogoFileReference="/content/dam/stylish/main-logo.png"
                    brandLogoLink="/content/stylish/en/en"
                    collectAllPages="true"
                    disableShadowing="false"
                    navigationRoot="/content/stylish/it/en"
                    structureDepth="2"
                    structureStart="1">
                    <iconsMenu
                        jcr:mixinTypes="[cq:LiveRelationship]"
                        jcr:primaryType="nt:unstructured">
                        <item0
                            jcr:mixinTypes="[cq:LiveRelationship]"
                            jcr:primaryType="nt:unstructured"
                            icon="user"
                            modalTarget="modallogin"/>
                        <item1
                            jcr:mixinTypes="[cq:LiveRelationship]"
                            jcr:primaryType="nt:unstructured"
                            icon="shopping-cart"
                            modalTarget="modallong"/>
                        <item2
                            jcr:mixinTypes="[cq:LiveRelationship]"
                            jcr:primaryType="nt:unstructured"
                            icon="search"
                            modalTarget="search-box"/>
                    </iconsMenu>
                </navigation>
            </hfcontainer>
        </root>
        <cq:LiveSyncConfig
            cq:isDeep="{Boolean}true"
            cq:master="/content/experience-fragments/stylish/it/en/site/header/master"
            cq:rolloutConfigs="[/libs/msm/wcm/rolloutconfigs/default]"
            jcr:primaryType="cq:LiveCopy"/>
    </jcr:content>
</jcr:root>
