<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:jcr="http://www.jcp.org/jcr/1.0" xmlns:nt="http://www.jcp.org/jcr/nt/1.0" xmlns:cq="http://www.day.com/jcr/cq/1.0" xmlns:sling="http://sling.apache.org/jcr/sling/1.0"
    jcr:primaryType="cq:Page">
    <jcr:content
        cq:template="/conf/stylish/settings/wcm/templates/stylish-page-home"
        jcr:primaryType="cq:PageContent"
        sling:resourceType="stylish/components/pagehome">
        <root
            jcr:primaryType="nt:unstructured"
            sling:resourceType="stylish/components/container"
            editable="{Boolean}false"
            layout="responsiveGrid">
            <xf-header
                jcr:primaryType="nt:unstructured"
                sling:resourceType="stylish/components/experiencefragment"
                fragmentVariationPath="/content/experience-fragments/stylish/it/en/site/header/master"/>
            <container
                jcr:primaryType="nt:unstructured"
                sling:resourceType="stylish/components/container"
                editable="{Boolean}true"
                layout="responsiveGrid"/>
            <xf-footer
                jcr:primaryType="nt:unstructured"
                sling:resourceType="stylish/components/experiencefragment"
                fragmentVariationPath="/content/experience-fragments/stylish/it/en/site/footer/master"/>
        </root>
    </jcr:content>
</jcr:root>
