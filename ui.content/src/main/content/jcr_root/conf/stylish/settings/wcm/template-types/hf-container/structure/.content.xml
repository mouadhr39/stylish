<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:jcr="http://www.jcp.org/jcr/1.0" xmlns:nt="http://www.jcp.org/jcr/nt/1.0" xmlns:cq="http://www.day.com/jcr/cq/1.0" xmlns:sling="http://sling.apache.org/jcr/sling/1.0"
    jcr:primaryType="cq:Page">
    <jcr:content
        cq:deviceGroups="[mobile/groups/responsive]"
        cq:template="/conf/stylish/settings/wcm/templates/empty-experience-fragment"
        jcr:primaryType="cq:PageContent"
        sling:resourceType="stylish/components/xfpage">
        <cq:responsive jcr:primaryType="nt:unstructured">
            <breakpoints jcr:primaryType="nt:unstructured">
                <phone
                    jcr:primaryType="nt:unstructured"
                    title="Smaller Screen"
                    width="{Long}768"/>
                <tablet
                    jcr:primaryType="nt:unstructured"
                    title="Tablet"
                    width="{Long}1200"/>
            </breakpoints>
        </cq:responsive>
        <root
            jcr:primaryType="nt:unstructured"
            sling:resourceType="stylish/components/container"
            editable="{Boolean}false">
            <hfcontainer
                jcr:primaryType="nt:unstructured"
                sling:resourceType="stylish/components/hfcontainer"
                editable="{Boolean}true"/>
        </root>
    </jcr:content>
</jcr:root>
