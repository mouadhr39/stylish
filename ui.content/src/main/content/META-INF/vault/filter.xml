    <filter root="/content/stylish" mode="merge"/>
    <filter root="/content/dam/stylish" mode="merge">
        <exclude pattern="/content/dam/stylish(/.*)?"/>
        <include pattern="/content/dam/stylish/jcr:content(/.*)?"/>
